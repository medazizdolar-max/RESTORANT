{
  "entities": {
    "Reservation": {
      "title": "Reservation",
      "description": "A table reservation at the restaurant.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string", "description": "Name of the person reserving." },
        "email": { "type": "string", "description": "Email of the person reserving." },
        "phone": { "type": "string", "description": "Phone number for contact." },
        "date": { "type": "string", "format": "date", "description": "Date of reservation." },
        "time": { "type": "string", "description": "Time of reservation." },
        "guests": { "type": "integer", "description": "Number of guests." },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"], "description": "Status of the reservation." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "phone", "date", "time", "guests"]
    },
    "User": {
      "title": "User",
      "description": "User profile with roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "reservations": {
      "schema": "Reservation",
      "description": "Collection of table reservations."
    },
    "users": {
      "schema": "User",
      "description": "Collection of user profiles."
    }
  }
}
